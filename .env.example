# Example environment variables for deployment (Railway)
# Set real values in Railway environment variables dashboard, do NOT commit real secrets here.

# Discord bot token
TOKEN_BOT=your_discord_bot_token_here

# Discord application client ID (from Developer Portal)
CLIENT_ID=your_application_client_id_here

# (Optional) Guild ID to register commands to a single guild for instant updates
GUILD_ID=your_guild_id_here

# (Optional) Channel/role IDs can remain in config/config.json or be provided here
#LOG_CHANNEL_ID=...
#TURA_CHANNEL_ID=...